APP_NAME="WA Campaign AI"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Karachi
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=wa_campaign
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ----------------------------------------------------------------------
# WhatsApp providers (pluggable). Set WHATSAPP_DRIVER to: meta | twilio
# ----------------------------------------------------------------------
WHATSAPP_DRIVER=meta

META_WA_PHONE_NUMBER_ID=
META_WA_BUSINESS_ACCOUNT_ID=
META_WA_ACCESS_TOKEN=
META_WA_VERIFY_TOKEN=change-me-webhook-verify
META_WA_API_VERSION=v21.0

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ----------------------------------------------------------------------
# AI providers. AI_TEXT_DRIVER: openai | anthropic
# ----------------------------------------------------------------------
AI_TEXT_DRIVER=openai
AI_IMAGE_DRIVER=openai

OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4o-mini
OPENAI_IMAGE_MODEL=dall-e-3
OPENAI_TTS_MODEL=tts-1-hd

ANTHROPIC_API_KEY=
ANTHROPIC_TEXT_MODEL=claude-sonnet-4-6

# ----------------------------------------------------------------------
# Voiceover (TTS). TTS_DRIVER: elevenlabs | openai
# ----------------------------------------------------------------------
TTS_DRIVER=elevenlabs
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL=eleven_multilingual_v2

# ----------------------------------------------------------------------
# Video generation. VIDEO_DRIVER: ffmpeg | heygen
# ----------------------------------------------------------------------
VIDEO_DRIVER=ffmpeg
FFMPEG_BINARY=/usr/bin/ffmpeg
FFPROBE_BINARY=/usr/bin/ffprobe

HEYGEN_API_KEY=
HEYGEN_AVATAR_ID=
HEYGEN_VOICE_ID=

# Auto-publish time (24h, APP_TIMEZONE) for scheduled posts
SCHEDULER_PUBLISH_HOUR=19
SCHEDULER_PUBLISH_MINUTE=0
